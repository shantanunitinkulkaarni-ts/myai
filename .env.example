API_BASE_URL=https://your-provider-base-url/v1
API_KEY=your_provider_api_key

MODEL_HAIKU=anthropic/claude-3.5-haiku
MODEL_SONNET=anthropic/claude-sonnet-4.6

# Folder where the coding agent can work.
# Set this to your project path.
WORKSPACE_DIR=C:/path/to/your/project

# Optional: if you use Google service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json

PORT=8787

# Saving mode — keeps costs low on ~100 INR budget
SAVE_MODE=true
MAX_AGENT_LOOPS=3
MAX_HISTORY_TURNS=4
MAX_TOKENS_CODE=400
MAX_TOKENS_HAIKU=250
MAX_TOKENS_SONNET=700
API_RETRY_COUNT=2

# Optional one-click deploy (approval required)
# GCP_DEPLOY_COMMAND=gcloud run deploy your-service --source . --region your-region
